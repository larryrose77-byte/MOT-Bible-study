---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { bibleGatewayUrl } from '../../lib/bibleGateway';

export async function getStaticPaths() {
  const studies = await getCollection('studies', ({ data }) => !data.draft);
  return studies.map((study) => ({
    params: { slug: study.id },
    props: { study },
  }));
}

const { study } = Astro.props;
const { Content } = await render(study);
const { title, date, passage, audioUrl, audioType, videoUrl, videoType, transcriptUrl, duration, summary } = study.data;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});
const passageUrl = bibleGatewayUrl(passage);
---
<BaseLayout title={title} description={summary}>
  <article class="study">
    <header class="study-header">
      <p class="study-meta">
        <time datetime={date.toISOString()}>{formattedDate}</time>
      </p>
      <h1>{title}</h1>
      <p class="study-passage-link">
        <a href={passageUrl} target="_blank" rel="noopener noreferrer">
          Read {passage} on Bible Gateway (NIV) &rarr;
        </a>
      </p>
      {summary && <p class="study-summary">{summary}</p>}
    </header>

    {videoUrl && (
      <section class="media">
        <h2>Video {duration && <span class="duration">({duration})</span>}</h2>
        <video controls preload="none" playsinline>
          <source src={videoUrl} type={videoType} />
          Your browser doesn't support video playback. <a href={videoUrl}>Download the video</a>.
        </video>
      </section>
    )}

    {audioUrl && !videoUrl && (
      <section class="media">
        <h2>Recording {duration && <span class="duration">({duration})</span>}</h2>
        <audio controls preload="none">
          <source src={audioUrl} type={audioType} />
          Your browser doesn't support audio playback.
          <a href={audioUrl}>Download the recording</a>.
        </audio>
      </section>
    )}

    {(audioUrl || videoUrl || transcriptUrl) && (
      <section class="downloads">
        <h2>Downloads</h2>
        <ul>
          {videoUrl && <li><a href={videoUrl} download>Video (MP4)</a></li>}
          {audioUrl && <li><a href={audioUrl} download>Audio (MP3/M4A)</a></li>}
          {transcriptUrl && <li><a href={transcriptUrl} download>Transcript (Word document)</a></li>}
        </ul>
      </section>
    )}

    <section class="notes prose">
      <Content />
    </section>

    <p class="back"><a href="/">&larr; All studies</a></p>
  </article>
</BaseLayout>
